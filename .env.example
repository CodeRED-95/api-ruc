POSTGRES_DB=sunat
POSTGRES_USER=sunat
POSTGRES_PASSWORD=sunat_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://sunat:sunat_password@postgres:5432/sunat
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true
CACHE_TTL_SECONDS=3600
API_ADMIN_KEY=change-this-admin-key
DEFAULT_DAILY_LIMIT=1000
DEFAULT_MINUTE_LIMIT=60
TOKEN_LENGTH=64
HASH_SECRET=change-this-hash-secret
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
PADRON_TABLE=padron_ruc
PADRON_DELIMITER=|
